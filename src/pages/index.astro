---
import PostCard from "../components/PostCard.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getPostUrlBySlug } from "@utils/url-utils";
import { getSortedPosts } from "../utils/content-utils";

const allPosts = await getSortedPosts();

const tabs = [
  {
    id: "thinking",
    label: "思考分享",
    icon: "🔥",
    slugs: ["agent-era-software-engineering", "agent-era-project-management", "agent-era-team-collaboration", "from-one-to-ten", "pain-points", "borrowing-and-absorption"],
  },
  {
    id: "engineering",
    label: "工程体系",
    icon: "⚙️",
    slugs: ["workflow-engine", "review-standards", "dispatch-patterns", "expert-skills", "auto-retro", "review-loop-control"],
  },
  {
    id: "fieldnotes",
    label: "实战笔记",
    icon: "📝",
    slugs: ["gui-automation", "memory-system", "gateway-restart"],
  },
];

const grouped = tabs.map(t => ({
  ...t,
  posts: t.slugs.map(slug => allPosts.find((p: any) => p.slug === slug)).filter(Boolean),
}));

let delay = 0;
const interval = 50;
---

<MainGridLayout>
  <!-- Pivot Tabs -->
  <div class="flex gap-1 mb-6 p-1 rounded-[var(--radius-large)] bg-[var(--card-bg)] onload-animation" style={`animation-delay: var(--content-delay)`} id="pivot-tabs">
    {tabs.map((tab, i) => (
      <button
        class:list={[
          "pivot-tab flex-1 py-2.5 px-4 rounded-[calc(var(--radius-large)-4px)] text-sm font-medium transition-all duration-200 cursor-pointer",
          i === 0 ? "active bg-[var(--btn-regular-bg)] text-[var(--primary)]" : "text-50 hover:text-75"
        ]}
        data-tab={tab.id}
      >
        <span class="mr-1">{tab.icon}</span>{tab.label}
      </button>
    ))}
  </div>

  <!-- Tab Content -->
  {grouped.map((section, sIdx) => (
    <div
      class:list={["tab-content transition flex flex-col rounded-[var(--radius-large)] bg-[var(--card-bg)] py-1 md:py-0 md:bg-transparent md:gap-4 mb-4", sIdx !== 0 && "hidden"]}
      data-content={section.id}
    >
      {section.posts.map((entry: any, i: number) => (
        <PostCard
          entry={entry}
          title={entry.data.title}
          tags={entry.data.tags}
          category={entry.data.category}
          published={entry.data.published}
          updated={entry.data.updated}
          url={getPostUrlBySlug(entry.slug)}
          style={`animation-delay: calc(var(--content-delay) + ${(delay++) * interval}ms)`}
          class="onload-animation"
        />
      ))}
    </div>
  ))}
</MainGridLayout>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const tabs = document.querySelectorAll('.pivot-tab');
  const contents = document.querySelectorAll('.tab-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');

      // Update tabs
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-[var(--btn-regular-bg)]', 'text-[var(--primary)]');
        t.classList.add('text-50');
      });
      tab.classList.add('active', 'bg-[var(--btn-regular-bg)]', 'text-[var(--primary)]');
      tab.classList.remove('text-50');

      // Update content
      contents.forEach(c => {
        if (c.getAttribute('data-content') === target) {
          c.classList.remove('hidden');
        } else {
          c.classList.add('hidden');
        }
      });
    });
  });
});

// Also handle swup page transitions
document.addEventListener('swup:page:view', () => {
  const tabs = document.querySelectorAll('.pivot-tab');
  const contents = document.querySelectorAll('.tab-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-[var(--btn-regular-bg)]', 'text-[var(--primary)]');
        t.classList.add('text-50');
      });
      tab.classList.add('active', 'bg-[var(--btn-regular-bg)]', 'text-[var(--primary)]');
      tab.classList.remove('text-50');
      contents.forEach(c => {
        if (c.getAttribute('data-content') === target) {
          c.classList.remove('hidden');
        } else {
          c.classList.add('hidden');
        }
      });
    });
  });
});
</script>
