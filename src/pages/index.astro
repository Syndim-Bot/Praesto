---
import PostCard from "../components/PostCard.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getPostUrlBySlug } from "@utils/url-utils";
import { getSortedPosts } from "../utils/content-utils";

const allPosts = await getSortedPosts();

// 按 category 自动分组，不再硬编码 slug
const categoryMap: Record<string, { label: string; icon: string; order: number }> = {
  "Field Notes": { label: "方法论", icon: "🔥", order: 1 },
  "Practice": { label: "实战笔记", icon: "📝", order: 4 },
  "Workflow": { label: "工作流与技能", icon: "🎓", order: 3 },
  "Quality": { label: "工程体系", icon: "⚙️", order: 2 },
  "Dispatch": { label: "工程体系", icon: "⚙️", order: 2 },
  "Skills": { label: "工作流与技能", icon: "🎓", order: 3 },
};

// 按 tab 分组
const tabGroups: Record<string, { label: string; icon: string; posts: any[] }> = {};

allPosts.forEach((post: any) => {
  const cat = post.data.category || "其他";
  const mapped = categoryMap[cat] || { label: "📦 其他", icon: "📦", order: 99 };
  const key = mapped.label;
  if (!tabGroups[key]) {
    tabGroups[key] = { label: mapped.label, icon: mapped.icon, posts: [] };
  }
  tabGroups[key].posts.push(post);
});

// 固定顺序
const tabs = [
  { id: "methodology", ...tabGroups["方法论"] || { label: "方法论", icon: "🔥", posts: [] } },
  { id: "practice", ...tabGroups["实战笔记"] || { label: "实战笔记", icon: "📝", posts: [] } },
  { id: "engineering", ...tabGroups["工程体系"] || { label: "工程体系", icon: "⚙️", posts: [] } },
  { id: "reusable", ...tabGroups["工作流与技能"] || { label: "工作流与技能", icon: "🎓", posts: [] } },
];

// 如果有其他分类
Object.entries(tabGroups).forEach(([key, val]) => {
  if (key !== "方法论" && key !== "实战笔记" && key !== "工程体系" && key !== "工作流与技能") {
    tabs.push({ id: key, ...val });
  }
});

let delay = 0;
const interval = 50;
---

<MainGridLayout>
  <!-- Pivot Tabs -->
  <div class="flex gap-1 mb-6 p-1 rounded-[var(--radius-large)] bg-[var(--card-bg)] onload-animation" style={`animation-delay: var(--content-delay)`} id="pivot-tabs">
    {tabs.map((tab, i) => (
      <button
        class:list={[
          "pivot-tab flex-1 py-2.5 px-4 rounded-[calc(var(--radius-large)-4px)] text-sm font-medium transition-all duration-200 cursor-pointer",
          i === 0 ? "active bg-[var(--btn-regular-bg)] text-[var(--primary)]" : "text-50 hover:text-75"
        ]}
        data-tab={tab.id}
      >
        <span class="mr-1">{tab.icon}</span>{tab.label}<span class="ml-1 text-xs opacity-60">({tab.posts.length})</span>
      </button>
    ))}
  </div>

  <!-- Tab Content -->
  {tabs.map((section, sIdx) => (
    <div
      class:list={["tab-content transition flex flex-col rounded-[var(--radius-large)] bg-[var(--card-bg)] py-1 md:py-0 md:bg-transparent md:gap-4 mb-4", sIdx !== 0 && "hidden"]}
      data-content={section.id}
    >
      {section.posts.map((entry: any) => (
        <PostCard
          entry={entry}
          title={entry.data.title}
          tags={entry.data.tags}
          category={entry.data.category}
          published={entry.data.published}
          updated={entry.data.updated}
          url={getPostUrlBySlug(entry.slug)}
          style={`animation-delay: calc(var(--content-delay) + ${(delay++) * interval}ms)`}
          class="onload-animation"
        />
      ))}
    </div>
  ))}

  <!-- Site Stats -->
  <div class="text-center text-sm text-50 mb-4 onload-animation" style="animation-delay: var(--content-delay)" id="site-stats">
    <span>👀 总访问 <strong id="site-views">-</strong></span>
    <span class="mx-3">❤️ 总喜爱 <strong id="site-likes">-</strong></span>
  </div>
</MainGridLayout>

<script>
const STATS_API = "https://praesto-stats.ou-gaochang.workers.dev";

// 加载全站统计
fetch(STATS_API + "/site-stats")
  .then(r => r.json())
  .then(d => {
    const v = document.getElementById("site-views");
    const l = document.getElementById("site-likes");
    if (v) v.textContent = d.views || 0;
    if (l) l.textContent = d.likes || 0;
  })
  .catch(() => {});



function initTabs() {
  const tabs = document.querySelectorAll('.pivot-tab');
  const contents = document.querySelectorAll('.tab-content');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-[var(--btn-regular-bg)]', 'text-[var(--primary)]');
        t.classList.add('text-50');
      });
      tab.classList.add('active', 'bg-[var(--btn-regular-bg)]', 'text-[var(--primary)]');
      tab.classList.remove('text-50');
      contents.forEach(c => {
        c.classList.toggle('hidden', c.getAttribute('data-content') !== target);
      });
    });
  });
}
document.addEventListener('DOMContentLoaded', initTabs);
document.addEventListener('swup:page:view', initTabs);
</script>
