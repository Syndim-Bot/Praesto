---
import PostCard from "../components/PostCard.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getPostUrlBySlug } from "@utils/url-utils";
import { getSortedPosts } from "../utils/content-utils";

const allPosts = await getSortedPosts();

// 按 category 自动分组，不再硬编码 slug
const categoryMap: Record<string, { label: string; icon: string; order: number }> = {
  "Field Notes": { label: "方法论", icon: "🔥", order: 1 },
  "Practice": { label: "实战笔记", icon: "📝", order: 4 },
  "Workflow": { label: "工作流与技能", icon: "🎓", order: 3 },
  "Quality": { label: "工程体系", icon: "⚙️", order: 2 },
  "Dispatch": { label: "工程体系", icon: "⚙️", order: 2 },
  "Skills": { label: "工作流与技能", icon: "🎓", order: 3 },
  "Automation": { label: "工作流与技能", icon: "🎓", order: 3 },
};

// 按 tab 分组
const tabGroups: Record<string, { label: string; icon: string; posts: any[] }> = {};

allPosts.forEach((post: any) => {
  const cat = post.data.category || "其他";
  const mapped = categoryMap[cat] || { label: "📦 其他", icon: "📦", order: 99 };
  const key = mapped.label;
  if (!tabGroups[key]) {
    tabGroups[key] = { label: mapped.label, icon: mapped.icon, posts: [] };
  }
  tabGroups[key].posts.push(post);
});

// 固定顺序
const tabs = [
  { id: "practice", ...tabGroups["实战笔记"] || { label: "实战笔记", icon: "📝", posts: [] } },
  { id: "methodology", ...tabGroups["方法论"] || { label: "方法论", icon: "🔥", posts: [] } },
  { id: "engineering", ...tabGroups["工程体系"] || { label: "工程体系", icon: "⚙️", posts: [] } },
  { id: "reusable", ...tabGroups["工作流与技能"] || { label: "工作流与技能", icon: "🎓", posts: [] } },
];

// 如果有其他分类
Object.entries(tabGroups).forEach(([key, val]) => {
  if (key !== "方法论" && key !== "实战笔记" && key !== "工程体系" && key !== "工作流与技能") {
    tabs.push({ id: key, ...val });
  }
});

let delay = 0;
const interval = 50;
---

<MainGridLayout>
    <!-- Pivot Tabs -->
  <div class="flex gap-1 mb-6 p-1 rounded-[var(--radius-large)] bg-[var(--card-bg)] onload-animation" style={`animation-delay: var(--content-delay)`} id="pivot-tabs">
    {tabs.map((tab, i) => (
      <button
        class:list={[
          "pivot-tab flex-1 py-2.5 px-4 rounded-[calc(var(--radius-large)-4px)] text-sm font-medium transition-all duration-200 cursor-pointer",
          i === 0 ? "active bg-[var(--btn-regular-bg)] text-[var(--primary)]" : "text-50 hover:text-75"
        ]}
        data-tab={tab.id}
      >
        <span class="mr-1">{tab.icon}</span>{tab.label}<span class="ml-1 text-xs opacity-60">({tab.posts.length})</span>
      </button>
    ))}
  </div>

  <!-- Tab Content -->
  {tabs.map((section, sIdx) => (
    <div
      class:list={["tab-content transition flex flex-col rounded-[var(--radius-large)] bg-[var(--card-bg)] py-1 md:py-0 md:bg-transparent md:gap-4 mb-4", sIdx !== 0 && "hidden"]}
      data-content={section.id}
    >
      {section.posts.map((entry: any) => (
        <PostCard
          entry={entry}
          title={entry.data.title}
          tags={entry.data.tags}
          category={entry.data.category}
          published={entry.data.published}
          updated={entry.data.updated}
          image={entry.data.image}
          description={entry.data.description}
          draft={entry.data.draft}
          url={getPostUrlBySlug(entry.slug)}
          style={`animation-delay: calc(var(--content-delay) + ${(delay++) * interval}ms)`}
          class="onload-animation"
        />
      ))}
    </div>
  ))}

  <!-- Site Stats -->
  <!-- Site Stats -->
  <div class="flex items-center justify-center gap-6 text-sm text-50 mb-4 onload-animation" style="animation-delay: var(--content-delay)" id="site-stats">
    <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" style="min-width:1em;display:inline;vertical-align:middle"><path fill="currentColor" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zm4 18H6V4h7v5h5z"/></svg> 页面访问 <strong id="site-pageviews">-</strong></span>
    <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" style="min-width:1em;display:inline;vertical-align:middle"><path d="M12 6.25c-4.7 0-8.38 2.45-10 5.75c1.62 3.3 5.3 5.75 10 5.75s8.38-2.45 10-5.75c-1.62-3.3-5.3-5.75-10-5.75Z" fill="currentColor" fill-opacity="0.06" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="4.2" fill="#C68642"/><circle cx="12" cy="12" r="3.2" fill="#8B5E3C" fill-opacity="0.95"/><circle cx="12" cy="12" r="1.8" fill="#3D2B1F" fill-opacity="0.92"/><path d="M9.15 10.2c.78-.72 1.73-1.08 2.85-1.08s2.07.36 2.85 1.08" stroke="#DEB887" stroke-width="1.1" stroke-linecap="round" opacity="0.95"/><circle cx="10.85" cy="10.7" r="0.72" fill="#FAEBD7"/></svg> 文章阅读 <strong id="site-views">-</strong></span>
    <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" style="color:#ef4444;min-width:1em;display:inline;vertical-align:middle"><path fill="currentColor" d="m12 21.35l-1.45-1.32C5.4 15.36 2 12.27 2 8.5C2 5.41 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.08C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.41 22 8.5c0 3.77-3.4 6.86-8.55 11.53z"/></svg> 总喜爱 <strong id="site-likes">-</strong></span>
  </div>

</MainGridLayout>

<script>
const STATS_API = "https://praesto-stats.ou-gaochang.workers.dev";

// 加载全站统计
// 加载全站统计
fetch(STATS_API + "/site-stats")
  .then(r => r.json())
  .then(d => {
    const pv = document.getElementById("site-pageviews");
    const v = document.getElementById("site-views");
    const l = document.getElementById("site-likes");
    if (pv) pv.textContent = d.pageviews || 0;
    if (v) v.textContent = d.views || 0;
    if (l) l.textContent = d.likes || 0;
  })
  .catch(() => {});



function loadPostStats() {
  // 加载阅读量
  document.querySelectorAll(".post-views[data-slug]").forEach(rawEl => {
    const el = rawEl as HTMLElement;
    const slug = el.dataset.slug;
    if (el.dataset.loaded) return;
    el.dataset.loaded = "1";
    fetch(STATS_API + "/stats/" + slug)
      .then(r => r.json())
      .then(d => {
        el.textContent = d.views || 0;
        // 已看过则换 emoji
        const viewedKey = "viewed:" + slug;
        if (localStorage.getItem(viewedKey)) {
          const vIcon = el.closest(".flex")?.querySelector(".post-view-icon");
          if (vIcon) vIcon.outerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" class="post-view-icon" style="min-width:1em"><path d="M12 6.25c-4.7 0-8.38 2.45-10 5.75c1.62 3.3 5.3 5.75 10 5.75s8.38-2.45 10-5.75c-1.62-3.3-5.3-5.75-10-5.75Z" fill="currentColor" fill-opacity="0.06" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="4.2" fill="#C68642"/><circle cx="12" cy="12" r="3.2" fill="#8B5E3C" fill-opacity="0.95"/><circle cx="12" cy="12" r="1.8" fill="#3D2B1F" fill-opacity="0.92"/><path d="M9.15 10.2c.78-.72 1.73-1.08 2.85-1.08s2.07.36 2.85 1.08" stroke="#DEB887" stroke-width="1.1" stroke-linecap="round" opacity="0.95"/><circle cx="10.85" cy="10.7" r="0.72" fill="#FAEBD7"/></svg>`;
        }
        // 填充喜爱数
        const card = el.closest(".card-base");
        if (card) {
          const likesEl = card.querySelector(".post-likes");
          if (likesEl) likesEl.textContent = d.likes || 0;
          // 如果已点赞，变红
          const likedKey = "liked:" + slug;
          if (localStorage.getItem(likedKey)) {
            const icon = card.querySelector(".post-like-icon");
            if (icon) icon.outerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" class="post-like-icon" style="color:#ef4444;min-width:1em"><path fill="currentColor" d="m12 21.35l-1.45-1.32C5.4 15.36 2 12.27 2 8.5C2 5.41 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.08C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.41 22 8.5c0 3.77-3.4 6.86-8.55 11.53z"/></svg>`;
          }
        }
      })
      .catch(() => {});
  });

  // 等所有 fetch 完成后按阅读量排序
  setTimeout(() => {
    document.querySelectorAll('.tab-content').forEach(tabContent => {
      // 获取每张卡片的阅读量
      const cardData: { card: Element; views: number }[] = [];
      tabContent.querySelectorAll('.post-views[data-slug]').forEach(el => {
        const card = el.closest('.card-base')?.parentElement || el.closest('.onload-animation');
        const views = parseInt(el.textContent) || 0;
        if (card && card.parentElement === tabContent) {
          cardData.push({ card, views });
        }
      });
      // 按阅读量降序排列
      cardData.sort((a, b) => b.views - a.views);
      cardData.forEach(({ card }) => tabContent.appendChild(card));
    });
  }, 1500); // 等 fetch 全部完成

  // 绑定点赞按钮
  document.querySelectorAll(".post-like-btn[data-slug]").forEach(rawBtn => {
    const btn = rawBtn as HTMLElement;
    if (btn.dataset.bound) return;
    btn.dataset.bound = "1";
    const slug = btn.dataset.slug;
    const likedKey = "liked:" + slug;

    btn.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (localStorage.getItem(likedKey)) return;
      fetch(STATS_API + "/like/" + slug, { method: "POST" })
        .then(r => r.json())
        .then(res => {
          const likesEl = btn.querySelector(".post-likes");
          if (likesEl) likesEl.textContent = res.likes;
          localStorage.setItem(likedKey, "1");
          const icon = btn.querySelector(".post-like-icon");
          if (icon) icon.outerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" class="post-like-icon" style="color:#ef4444;min-width:1em"><path fill="currentColor" d="m12 21.35l-1.45-1.32C5.4 15.36 2 12.27 2 8.5C2 5.41 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.08C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.41 22 8.5c0 3.77-3.4 6.86-8.55 11.53z"/></svg>`;
          const sl = document.getElementById("site-likes");
          if (sl) sl.textContent = String(parseInt(sl.textContent || "0") + 1);
        })
        .catch(() => {});
    });
  });
}

function initTabs() {
  const tabs = document.querySelectorAll('.pivot-tab');
  const contents = document.querySelectorAll('.tab-content');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-[var(--btn-regular-bg)]', 'text-[var(--primary)]');
        t.classList.add('text-50');
      });
      tab.classList.add('active', 'bg-[var(--btn-regular-bg)]', 'text-[var(--primary)]');
      tab.classList.remove('text-50');
      contents.forEach(c => {
        c.classList.toggle('hidden', c.getAttribute('data-content') !== target);
      });
      history.replaceState(null, '', '?tab=' + target);
    });
  });
}
document.addEventListener('DOMContentLoaded', () => { 
  initTabs(); 
  loadPostStats();
  // 读取 URL hash 切换 tab
  const hash = new URLSearchParams(window.location.search).get('tab');
  if (hash) {
    const tab = document.querySelector('.pivot-tab[data-tab="' + hash + '"]') as HTMLElement | null;
    if (tab) tab.click();
  }
});
document.addEventListener('swup:page:view', () => { initTabs(); loadPostStats(); });
</script>
